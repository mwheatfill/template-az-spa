{
  "name": "template-az-spa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Tier 1 SPA template: Vite + React 19 + TS + Tailwind v4 + shadcn + TanStack Router/Query, deployed to Azure Static Web Apps with Entra ID auth.",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "vite",
    "dev:swa": "swa start http://localhost:5173 --run \"npm run dev\" --api-location api",
    "routes:generate": "tsr generate",
    "prebuild": "npm run routes:generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "pretypecheck": "npm run routes:generate",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "skills:install": "intent install",
    "diagnose": "bash scripts/diagnose.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@microsoft/applicationinsights-react-js": "^19.4.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.6",
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.5",
    "@tanstack/intent": "^0.0.40",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-cli": "^1.166.43",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
